{
  "info": {
    "name": "BankFlow API Collection",
    "description": "Complete API collection for BankFlow — Cloud-Native Open Banking Analytics Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url_auth", "value": "http://localhost:8001" },
    { "key": "base_url_banking", "value": "http://localhost:8002" },
    { "key": "base_url_analytics", "value": "http://localhost:8003" },
    { "key": "auth_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "api_key", "value": "" },
    { "key": "account_id", "value": "" },
    { "key": "consent_id", "value": "" },
    { "key": "payment_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url_auth}}/health"
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{base_url_auth}}/v1/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@bankflow.dev\",\n  \"username\": \"testuser\",\n  \"password\": \"SecurePass123!\",\n  \"full_name\": \"Test User\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "  pm.collectionVariables.set('auth_token', jsonData.access_token);",
                  "  pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url_auth}}/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "  pm.collectionVariables.set('auth_token', jsonData.access_token);",
                  "  pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url_auth}}/v1/auth/token/refresh",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Create API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.api_key) {",
                  "  pm.collectionVariables.set('api_key', jsonData.api_key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url_auth}}/v1/auth/api-key",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"my-api-key\"\n}"
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "url": "{{base_url_auth}}/v1/auth/verify",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Banking API Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url_banking}}/health"
          }
        },
        {
          "name": "Seed Demo Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.account_id) {",
                  "  pm.collectionVariables.set('account_id', jsonData.account_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url_banking}}/v1/demo/seed",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ]
          }
        },
        {
          "name": "Create Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "  pm.collectionVariables.set('payment_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url_banking}}/v1/payments",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"debtor_account_id\": \"{{account_id}}\",\n  \"creditor_account_id\": \"GB29NWBK60161331926819\",\n  \"creditor_name\": \"Jane Smith\",\n  \"amount\": 150.00,\n  \"currency\": \"GBP\",\n  \"payment_reference\": \"Invoice-001\"\n}"
            }
          }
        },
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url_banking}}/v1/accounts/{{account_id}}/transactions?limit=20",
              "host": ["{{base_url_banking}}"],
              "path": ["v1", "accounts", "{{account_id}}", "transactions"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ]
          }
        },
        {
          "name": "Create Consent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "  pm.collectionVariables.set('consent_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url_banking}}/v1/consent",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tpp_id\": \"00000000-0000-0000-0000-000000000001\",\n  \"permissions\": [\"ReadAccountsBasic\", \"ReadTransactionsDetail\"],\n  \"expires_in_days\": 90\n}"
            }
          }
        },
        {
          "name": "Get Consent",
          "request": {
            "method": "GET",
            "url": "{{base_url_banking}}/v1/consent/{{consent_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ]
          }
        },
        {
          "name": "Webhook Payment Status",
          "request": {
            "method": "POST",
            "url": "{{base_url_banking}}/v1/webhooks/payment-status",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_id\": \"{{payment_id}}\",\n  \"new_status\": \"completed\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url_analytics}}/health"
          }
        },
        {
          "name": "Analytics Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url_analytics}}/v1/analytics/summary"
          }
        },
        {
          "name": "Fraud Distribution",
          "request": {
            "method": "GET",
            "url": "{{base_url_analytics}}/v1/analytics/fraud-distribution"
          }
        },
        {
          "name": "Spend by Category",
          "request": {
            "method": "GET",
            "url": "{{base_url_analytics}}/v1/analytics/spend-by-category"
          }
        }
      ]
    }
  ]
}
