# ============================================================
# BankFlow — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ---- General ----
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Service URLs ----
AUTH_SERVICE_URL=http://auth-service:8001
BANKING_API_URL=http://banking-api-service:8002
ANALYTICS_SERVICE_URL=http://analytics-service:8003

# ---- PostgreSQL ----
DATABASE_URL=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bankflow
POSTGRES_USER=bankflow_user
POSTGRES_PASSWORD=change_me_in_production

# ---- Redis ----
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Auth & Security ----
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
# Fallback HS256 secret
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
API_KEY_SECRET=change-this-api-key-secret-in-production

# ---- Rate Limiting & Cache ----
RATE_LIMIT_PER_MINUTE=100
ANALYTICS_CACHE_TTL=60

# ---- Frontend ----
VITE_AUTH_API_URL=http://localhost:8001
VITE_BANKING_API_URL=http://localhost:8002
VITE_ANALYTICS_API_URL=http://localhost:8003
VITE_WS_URL=ws://localhost:8002

# ---- Kafka / Redpanda (Optional) ----
KAFKA_BROKER=redpanda:9092
KAFKA_TOPIC=transactions

# ---- AWS (Phase 12 — Optional) ----
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
S3_RAW_BUCKET=bankflow-raw-data
S3_PROCESSED_BUCKET=bankflow-processed-data
