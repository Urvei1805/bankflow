# ============================================================
# BankFlow — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ---- General ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bankflow
POSTGRES_USER=bankflow_user
POSTGRES_PASSWORD=change_me_in_production

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Auth Service ----
AUTH_SERVICE_PORT=8001
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Generate RSA keys: openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
# Fallback HS256 secret (used only if RSA keys are not available)
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production

# ---- Banking API Service ----
BANKING_SERVICE_PORT=8002
RATE_LIMIT_PER_MINUTE=100
AUTH_SERVICE_URL=http://auth-service:8001

# ---- Analytics Service ----
ANALYTICS_SERVICE_PORT=8003
ANALYTICS_CACHE_TTL=60

# ---- Frontend ----
VITE_AUTH_API_URL=http://localhost:8001
VITE_BANKING_API_URL=http://localhost:8002
VITE_ANALYTICS_API_URL=http://localhost:8003
VITE_WS_URL=ws://localhost:8002

# ---- Kafka / Redpanda (Optional) ----
KAFKA_BROKER=redpanda:9092
KAFKA_TOPIC=transactions

# ---- AWS (Phase 12 — Optional) ----
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
S3_RAW_BUCKET=bankflow-raw-data
S3_PROCESSED_BUCKET=bankflow-processed-data
